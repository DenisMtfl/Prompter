@using System.Globalization
@inject IStringLocalizer<SharedResource> L
@inject NavigationManager Navigation
@inject IJSRuntime JsRuntime

<div class="dropdown">
    <button class="btn btn-outline-secondary btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
        @CurrentCultureLabel
    </button>
    <ul class="dropdown-menu dropdown-menu-end">
        <li><button class="dropdown-item" type="button" @onclick='() => SelectLanguageAsync("de")'>@L["Language_German"]</button></li>
        <li><button class="dropdown-item" type="button" @onclick='() => SelectLanguageAsync("en")'>@L["Language_English"]</button></li>
    </ul>
</div>

@code {
    private static readonly HashSet<string> LocalizedCoreSegments =
    [
        "generator",
        "optimizer",
        "presets",
        "faq",
        "history",
        "favorites",
        "license"
    ];

    private string CurrentCultureLabel => CultureInfo.CurrentUICulture.TwoLetterISOLanguageName.Equals("de", StringComparison.OrdinalIgnoreCase)
        ? L["Language_German"]
        : L["Language_English"];

    private string BuildCultureUrl(string culture)
    {
        var targetCulture = culture.Equals("en", StringComparison.OrdinalIgnoreCase) ? "en" : "de";
        var current = new Uri(Navigation.Uri);
        var path = current.AbsolutePath;
        var query = current.Query;

        var segments = path
            .Split('/', StringSplitOptions.RemoveEmptyEntries)
            .ToList();

        if (segments.Count == 0)
        {
            return AppRoutes.HomePath;
        }

        var first = segments[0].ToLowerInvariant();
        var hasCulturePrefix = first is "de" or "en";

        if (hasCulturePrefix)
        {
            if (segments.Count == 1)
            {
                return AppRoutes.HomePath;
            }

            var second = segments[1].ToLowerInvariant();
            if (LocalizedCoreSegments.Contains(second))
            {
                segments[0] = targetCulture;
                return $"/{string.Join('/', segments)}{query}";
            }

            return AppRoutes.HomePath;
        }

        if (path.Equals("/", StringComparison.Ordinal))
        {
            return AppRoutes.HomePath;
        }

        if (LocalizedCoreSegments.Contains(first))
        {
            return $"/{targetCulture}/{string.Join('/', segments)}{query}";
        }

        return AppRoutes.HomePath;
    }

    private async Task SelectLanguageAsync(string culture)
    {
        var normalized = await JsRuntime.InvokeAsync<string>("promptLanguage.set", culture);
        Navigation.NavigateTo(BuildCultureUrl(normalized), forceLoad: true);
    }
}
