@implements IDisposable
@using System.Globalization
@inject IStringLocalizer<SharedResource> L
@inject IThemeService ThemeService
@inject IUserLibraryService UserLibraryService

<header class="app-navbar sticky-top border-bottom">
    <nav class="navbar navbar-expand-lg">
        <div class="container">
            <NavLink class="navbar-brand fw-semibold" href="@LandingPath" Match="NavLinkMatch.All">PromptForge</NavLink>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="@L["Nav_Toggle"]">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <NavLink class="nav-link" href="@LandingPath" Match="NavLinkMatch.All">@L["Nav_Landing"]</NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link" href="@GeneratorPath">@L["Nav_Generator"]</NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link" href="@OptimizerPath">@L["Nav_Optimizer"]</NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link" href="@PresetsPath">@L["Nav_Presets"]</NavLink>
                    </li>
                    @if (UserLibraryService.IsHistoryEnabled)
                    {
                        <li class="nav-item">
                            <NavLink class="nav-link" href="@HistoryPath">@L["Nav_History"]</NavLink>
                        </li>
                    }
                    <li class="nav-item">
                        <NavLink class="nav-link" href="@FavoritesPath">@L["Nav_Favorites"]</NavLink>
                    </li>
                </ul>

                <div class="d-flex align-items-center gap-2 navbar-actions">
                    <LanguageSwitcher />
                    <button class="btn btn-outline-secondary btn-sm" @onclick="ToggleTheme">
                        @(IsDarkTheme ? L["Theme_Dark"] : L["Theme_Light"])
                    </button>
                </div>
            </div>
        </div>
    </nav>
</header>

@code {
    private bool IsDarkTheme => ThemeService.CurrentTheme.Equals("dark", StringComparison.OrdinalIgnoreCase);
    private string CurrentLanguage => CultureInfo.CurrentUICulture.TwoLetterISOLanguageName.Equals("de", StringComparison.OrdinalIgnoreCase)
        ? "de"
        : "en";

    private string LandingPath => AppRoutes.HomePathForCulture(CurrentLanguage);
    private string GeneratorPath => AppRoutes.GeneratorPathForCulture(CurrentLanguage);
    private string OptimizerPath => AppRoutes.OptimizerPathForCulture(CurrentLanguage);
    private string PresetsPath => AppRoutes.PresetsPathForCulture(CurrentLanguage);
    private string HistoryPath => AppRoutes.HistoryPathForCulture(CurrentLanguage);
    private string FavoritesPath => AppRoutes.FavoritesPathForCulture(CurrentLanguage);

    protected override void OnInitialized()
    {
        ThemeService.Changed += OnThemeChanged;
    }

    private async Task ToggleTheme()
    {
        await ThemeService.ToggleAsync();
    }

    private void OnThemeChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        ThemeService.Changed -= OnThemeChanged;
    }
}
