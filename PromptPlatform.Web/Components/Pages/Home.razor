@page "/"
@page "/de"
@page "/en"
@using System.Text.Json
@inject IStringLocalizer<SharedResource> L
@inject ISeoLandingPageService SeoLandingPageService
@inject IPresetService PresetService
@inject IExperimentService ExperimentService
@inject NavigationManager Navigation

<PageTitle>@HomeTitle</PageTitle>
<HeadContent>
    <meta name="application-name" content="PromptToMars" />
    <meta name="description" content="@HomeMetaDescription" />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="@HomeTitle" />
    <meta property="og:description" content="@HomeMetaDescription" />
    <meta property="og:site_name" content="PromptToMars" />
    <meta property="og:url" content="@CanonicalUrl" />
    <meta property="og:locale" content="@(IsGerman ? "de_DE" : "en_US")" />
    <meta property="og:locale:alternate" content="@(IsGerman ? "en_US" : "de_DE")" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@HomeTitle" />
    <meta name="twitter:description" content="@HomeMetaDescription" />
    <link rel="canonical" href="@CanonicalUrl" />
    <link rel="alternate" hreflang="de" href="@GermanHomeUrl" />
    <link rel="alternate" hreflang="en" href="@EnglishHomeUrl" />
    <link rel="alternate" hreflang="x-default" href="@EnglishHomeUrl" />
    <script type="application/ld+json">@((MarkupString)HomeJsonLd)</script>
    <script type="application/ld+json">@((MarkupString)HomeNavigationJsonLd)</script>
    <script type="application/ld+json">@((MarkupString)ImageMetadataJsonLd)</script>
</HeadContent>

<div class="landing-page awesome-shell">
    <section class="hero-section landing-hero awesome-hero rounded-4 p-4 p-lg-5 mb-5">
        <div class="row g-4 align-items-center">
            <div class="col-lg-8">
                <div class="hero-brand-stack mb-2">
                    <span class="badge text-bg-primary awesome-kicker">@L["Landing_HeroBadge"]</span>
                    <div class="hero-wordmark">PromptToMars</div>
                </div>
                <p class="awesome-tagline mb-1">@HeroSlogan</p>
                <p class="hero-catchline mb-3">@HeroCatchline</p>
                <h1 class="display-5 fw-bold mb-3">@L["Landing_HeroTitle"]</h1>
                <p class="lead mb-4">@L["Landing_HeroSubtitle"]</p>
                <div class="d-flex flex-wrap gap-2 mb-4">
                    <span class="landing-count-badge">@HeroPresetCountLabel</span>
                </div>
                <div class="d-flex flex-wrap gap-2">
                    <a class="btn btn-primary btn-lg"
                       href="@GeneratorPath"
                       data-track="landing.cta.primary"
                       data-track-context="@CurrentLanguage"
                       data-exp-key="@HeroExperimentKey"
                       data-exp-variant="@HeroExperimentVariant">@PrimaryCtaLabel</a>
                    <a class="btn btn-outline-secondary btn-lg"
                       href="@PresetsPath"
                       data-track="landing.cta.secondary"
                       data-track-context="@CurrentLanguage">@L["Landing_CtaSecondary"]</a>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="hero-logo-panel mb-3">
                    <img src="/images/PromptToMars-logo.png" alt="@HeroLogoAlt" class="hero-logo-transparent" loading="eager" decoding="async" />
                </div>
                <div class="card shadow-sm border-0 h-100 hero-facts-card awesome-facts-card">
                    <div class="card-body">
                        <h2 class="h5 mb-3">@L["Landing_QuickFacts_Title"]</h2>
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item px-0">@L["Landing_QuickFacts_Item1"]</li>
                            <li class="list-group-item px-0">@L["Landing_QuickFacts_Item2"]</li>
                            <li class="list-group-item px-0">@L["Landing_QuickFacts_Item3"]</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="mb-5" aria-labelledby="landing-search-title">
        <div class="card border-0 shadow-sm awesome-search-card">
            <div class="card-body p-4">
                <h2 id="landing-search-title" class="h5 mb-2">@SearchSectionTitle</h2>
                <p class="text-secondary small mb-3">@SearchSectionSubtitle</p>
                <form class="awesome-search-form" method="get" action="@PresetsPath">
                    <input class="form-control form-control-lg" type="search" name="search" placeholder="@SearchPlaceholder" />
                    <button class="btn btn-primary" type="submit">@SearchButtonLabel</button>
                </form>
            </div>
        </div>
    </section>

    <section class="mb-5 landing-section" aria-labelledby="cluster-title">
        <div class="d-flex flex-wrap justify-content-between align-items-end gap-2 mb-3">
            <div>
                <h2 id="cluster-title" class="h3 mb-1">@ClusterTitle</h2>
                <p class="text-secondary mb-0">@ClusterSubtitle</p>
            </div>
            <a class="link-secondary text-decoration-none"
               href="@PresetsPath"
               data-track="landing.cluster.browse"
               data-track-context="@CurrentLanguage">@ClusterAction</a>
        </div>

        <div class="row g-3 awesome-browse-grid">
            @foreach (var clusterPage in ClusterPages)
            {
                <div class="col-md-6 col-xl-4">
                    <div class="card border-0 shadow-sm h-100 cluster-hub-card awesome-browse-card">
                        <div class="card-body d-flex flex-column">
                            <div class="awesome-browse-icon mb-2">@GetClusterIcon(clusterPage.Category)</div>
                            <h3 class="h5">@clusterPage.Title</h3>
                            <p class="text-secondary small">@clusterPage.Description</p>
                            <div class="mt-auto d-flex gap-2 flex-wrap">
                                <a class="btn btn-sm btn-outline-secondary"
                                   href="@clusterPage.Path"
                                   data-track="landing.cluster.page"
                                   data-track-context="@clusterPage.Key">@ClusterPageButton</a>
                                <a class="btn btn-sm btn-primary"
                                   href="@($"{PresetsPath}?category={clusterPage.Category}")"
                                   data-track="landing.cluster.presets"
                                   data-track-context="@clusterPage.Category">@ClusterPresetsButton</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </section>

    @if (FeaturedPresets.Count > 0)
    {
        <section class="mb-5 landing-section" aria-labelledby="featured-presets-title">
            <div class="d-flex flex-wrap justify-content-between align-items-end gap-2 mb-3">
                <div>
                    <h2 id="featured-presets-title" class="h3 mb-1">@FeaturedPresetsTitle</h2>
                    <p class="text-secondary mb-0">@FeaturedPresetsSubtitle</p>
                </div>
                <a class="link-secondary text-decoration-none"
                   href="@PresetsPath"
                   data-track="landing.featured-presets.browse"
                   data-track-context="@CurrentLanguage">@ClusterAction</a>
            </div>

            <div class="row g-3">
                @foreach (var preset in FeaturedPresets)
                {
                    var landingPath = GetCategoryLandingPath(preset);

                    <div class="col-md-6 col-xl-4">
                        <div class="card border-0 shadow-sm h-100 feature-card-modern">
                            <div class="card-body d-flex flex-column">
                                <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                                    <h3 class="h5 mb-0">@preset.GetTitle(CurrentLanguage)</h3>
                                    <span class="badge rounded-pill text-bg-light border">@GetCategoryLabel(preset.Category)</span>
                                </div>
                                <p class="text-secondary small">@preset.GetDescription(CurrentLanguage)</p>
                                <div class="small text-secondary mb-3">
                                    @preset.GetSubcategory(CurrentLanguage) · @preset.DefaultPlatform
                                </div>
                                <div class="mt-auto d-flex gap-2 flex-wrap">
                                    <a class="btn btn-sm btn-primary"
                                       href="@AppRoutes.PromptPathForPreset(preset.Slug)"
                                       data-track="landing.featured-presets.use"
                                       data-track-context="@preset.Category">@FeaturedPresetUseLabel</a>
                                    @if (!string.IsNullOrWhiteSpace(landingPath))
                                    {
                                        <a class="btn btn-sm btn-outline-secondary"
                                           href="@landingPath"
                                           data-track="landing.featured-presets.landing"
                                           data-track-context="@preset.Category">@FeaturedPresetLandingLabel</a>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </section>
    }

    <section class="mb-5 landing-section">
        <h2 class="h3 mb-3">@L["Landing_Features_Title"]</h2>
        <div class="row g-3">
            @foreach (var feature in FeatureCards)
            {
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm h-100 feature-card-modern">
                        <div class="card-body">
                            <h3 class="h5">@L[feature.TitleKey]</h3>
                            <p class="text-secondary mb-0">@L[feature.DescriptionKey]</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    </section>

    <section class="landing-section">
        <div class="card border-0 shadow-sm workflow-card">
            <div class="card-body p-4 p-lg-5">
                <h2 class="h3 mb-3">@L["Landing_Workflow_Title"]</h2>
                <div class="row g-4">
                    <div class="col-md-4">
                        <h3 class="h6 text-primary">01</h3>
                        <p class="mb-0">@L["Landing_Workflow_Step1"]</p>
                    </div>
                    <div class="col-md-4">
                        <h3 class="h6 text-primary">02</h3>
                        <p class="mb-0">@L["Landing_Workflow_Step2"]</p>
                    </div>
                    <div class="col-md-4">
                        <h3 class="h6 text-primary">03</h3>
                        <p class="mb-0">@L["Landing_Workflow_Step3"]</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="landing-section mt-4">
        <div class="card border-0 shadow-sm workflow-card">
            <div class="card-body p-4 p-lg-5">
                <h2 class="h3 mb-2">@FaqSectionTitle</h2>
                <p class="text-secondary mb-3">@FaqSectionSubtitle</p>
                <div class="d-flex flex-wrap gap-2">
                    <a class="btn btn-outline-secondary"
                       href="@FaqPath"
                       data-track="landing.faq.open"
                       data-track-context="@CurrentLanguage">@FaqSectionCta</a>
                    <a class="btn btn-outline-secondary"
                       href="@OptimizerPath"
                       data-track="landing.optimizer.open"
                       data-track-context="@CurrentLanguage">@OptimizerSectionCta</a>
                </div>
            </div>
        </div>
    </section>
</div>

@code {
    private IReadOnlyList<SeoLandingPageLinkViewModel> ClusterPages { get; set; } = [];
    private IReadOnlyList<PromptPreset> FeaturedPresets { get; set; } = [];

    private static readonly IReadOnlyList<(string TitleKey, string DescriptionKey)> FeatureCards =
    [
        ("Landing_Feature_Generator_Title", "Landing_Feature_Optimizer_Desc"),
        ("Landing_Feature_Optimizer_Title", "Landing_Feature_Optimizer_Desc"),
        ("Landing_Feature_Library_Title", "Landing_Feature_Library_Desc")
    ];

    private string CurrentLanguage => CultureInfo.CurrentUICulture.TwoLetterISOLanguageName.Equals("de", StringComparison.OrdinalIgnoreCase)
        ? "de"
        : "en";

    private bool IsGerman => CurrentLanguage == "de";

    private string ClusterTitle => IsGerman ? "Themencluster für KI-Prompts und organisches Wachstum" : "Topic clusters for AI prompts and organic growth";
    private string ClusterSubtitle => IsGerman
        ? "Jede Landingpage bildet ein eigenes Cluster und verlinkt auf passende Prompt-Vorlagen, Presets und verwandte Themenbereiche."
        : "Each landing page forms its own cluster and links to matching prompt templates, presets, and related topic pages.";
    private string ClusterAction => IsGerman ? "Alle Presets durchsuchen" : "Browse all presets";
    private string ClusterPageButton => IsGerman ? "Landingpage" : "Landing page";
    private string ClusterPresetsButton => IsGerman ? "Presets" : "Presets";
    private string FeaturedPresetsTitle => IsGerman ? "Beliebte KI-Prompt-Vorlagen als SEO-Einstieg" : "Popular AI prompt templates as SEO entry points";
    private string FeaturedPresetsSubtitle => IsGerman
        ? "Diese kuratierten Presets verbinden organische Einstiegsseiten direkt mit konkreten Prompt-Generator-Workflows."
        : "These curated presets connect organic entry pages directly with concrete prompt-generator workflows.";
    private string FeaturedPresetUseLabel => IsGerman ? "Preset starten" : "Start preset";
    private string FeaturedPresetLandingLabel => IsGerman ? "Themenseite" : "Topic page";
    private string GeneratorPath => AppRoutes.GeneratorPathForCulture(CurrentLanguage);
    private string OptimizerPath => AppRoutes.OptimizerPathForCulture(CurrentLanguage);
    private string PresetsPath => AppRoutes.PresetsPathForCulture(CurrentLanguage);
    private string FaqPath => AppRoutes.FaqPathForCulture(CurrentLanguage);
    private string FaqSectionTitle => IsGerman ? "Häufige Fragen und Produktwissen" : "Frequently asked questions and product guidance";
    private string FaqSectionSubtitle => IsGerman
        ? "Alle Details zu Prompt-Qualität, Prompt-Vorlagen, SEO-Struktur und Skalierung findest du in der ausführlichen FAQ."
        : "Find detailed guidance on prompt quality, prompt templates, SEO structure, and scalability in the full FAQ.";
    private string FaqSectionCta => IsGerman ? "FAQ öffnen" : "Open FAQ";
    private string OptimizerSectionCta => IsGerman ? "Optimizer öffnen" : "Open optimizer";
    private string SearchSectionTitle => IsGerman ? "Alle Ressourcen durchsuchen" : "Search all resources";
    private string SearchSectionSubtitle => IsGerman
        ? "Suche direkt nach KI-Prompts, Prompt-Vorlagen, Presets und Kategorien für deinen Anwendungsfall."
        : "Search directly for AI prompts, prompt templates, presets, and categories for your use case.";
    private string SearchPlaceholder => IsGerman ? "Mindestens zwei Zeichen eingeben…" : "Type at least two characters…";
    private string SearchButtonLabel => IsGerman ? "Suche" : "Search";
    private string HeroExperimentKey => "landing_primary_cta";
    private string HeroExperimentVariant { get; set; } = "A";
    private string PrimaryCtaLabel => HeroExperimentVariant == "B"
        ? (IsGerman ? "Jetzt Prompt erstellen" : "Create prompt now")
        : L["Landing_CtaPrimary"];
    private string HeroSlogan => IsGerman
        ? "Von der Idee bis zur Wirkung — PromptToMars bringt deine Prompts auf ein neues Level."
        : "From first idea to real impact — PromptToMars takes your prompts to the next level.";
    private string HeroCatchline => IsGerman
        ? "Schneller. Präziser. Unvergesslich bessere Prompts."
        : "Faster. Sharper. Unforgettable prompts.";
    private string HeroLogoAlt => IsGerman ? "PromptToMars Logo als Hero-Visual" : "PromptToMars logo as hero visual";

    private string HomeTitle => IsGerman
        ? "KI Prompt Generator, Prompt Optimizer, Prompt-Vorlagen & Shareable Prompts | PromptToMars"
        : "AI Prompt Generator, Prompt Optimizer, Prompt Templates & Shareable Prompts | PromptToMars";
    private string HomeMetaDescription => IsGerman
        ? "PromptToMars ist eine Plattform für KI Prompt Generator, Prompt Optimizer, Prompt-Vorlagen, teilbare Prompt-Links, Presets, Prompt Engineering und SEO-Landingpages. Erstelle bessere ChatGPT-Prompts und skaliere deine Themencluster effizient."
        : "PromptToMars is a platform for an AI prompt generator, prompt optimizer, prompt templates, shareable prompt links, presets, prompt engineering, and SEO landing pages. Create better ChatGPT prompts and scale your topic clusters efficiently.";
    private int TotalPresetCount { get; set; }
    private string HeroPresetCountLabel => IsGerman
        ? $"{TotalPresetCount.ToString("N0", CultureInfo.CurrentCulture)} Presets verfügbar"
        : $"{TotalPresetCount.ToString("N0", CultureInfo.CurrentCulture)} presets available";
    private string CanonicalUrl => ToAbsolute(IsGerman ? "/de" : "/en");
    private string GermanHomeUrl => ToAbsolute("/de");
    private string EnglishHomeUrl => ToAbsolute("/en");
    private string LicenseUrl => ToAbsolute(AppRoutes.LicensePathForCulture(CurrentLanguage));
    private string AcquireLicenseUrl => $"{LicenseUrl}#acquire";
    private string SiteImageUrl => ToAbsolute("/favicon.png");
    private string ImageMetadataJsonLd => JsonSerializer.Serialize(new
    {
        @context = "https://schema.org",
        @type = "ImageObject",
        contentUrl = SiteImageUrl,
        url = SiteImageUrl,
        creditText = "PromptToMars",
        acquireLicensePage = AcquireLicenseUrl,
        license = LicenseUrl,
        copyrightNotice = $"© {DateTime.UtcNow.Year} PromptToMars"
    });
    private string HomeJsonLd => JsonSerializer.Serialize(new
    {
        @context = "https://schema.org",
        @graph = new object[]
        {
            new
            {
                @type = "Organization",
                name = "PromptToMars",
                url = ToAbsolute("/"),
                sameAs = Array.Empty<string>()
            },
            new
            {
                @type = "WebSite",
                name = "PromptToMars",
                url = ToAbsolute("/"),
                inLanguage = new[] { "de", "en" },
                publisher = new
                {
                    @type = "Organization",
                    name = "PromptToMars"
                }
            },
            new
            {
                @type = "SoftwareApplication",
                name = "PromptToMars",
                applicationCategory = "BusinessApplication",
                operatingSystem = "Web",
                offers = new { @type = "Offer", price = "0", priceCurrency = "USD" },
                url = CanonicalUrl,
                description = HomeMetaDescription
            },
            new
            {
                @type = "ItemList",
                name = FeaturedPresetsTitle,
                itemListElement = FeaturedPresets
                    .Select((preset, index) => new
                    {
                        @type = "ListItem",
                        position = index + 1,
                        name = preset.GetTitle(CurrentLanguage),
                        url = ToAbsolute(AppRoutes.PromptPathForPreset(preset.Slug))
                    })
                    .ToArray()
            }
        }
    });
    private string HomeNavigationJsonLd => JsonSerializer.Serialize(new
    {
        @context = "https://schema.org",
        @graph = new object[]
        {
            new
            {
                @type = "ItemList",
                name = ClusterTitle,
                itemListElement = ClusterPages
                    .Select((page, index) => new
                    {
                        @type = "ListItem",
                        position = index + 1,
                        name = page.Title,
                        url = ToAbsolute(page.Path)
                    })
                    .ToArray()
            },
            new { @type = "SiteNavigationElement", name = HomeTitle, url = CanonicalUrl },
            new { @type = "SiteNavigationElement", name = L["PageTitle_Presets"].Value, url = ToAbsolute(PresetsPath) },
            new { @type = "SiteNavigationElement", name = L["PageTitle_Faq"].Value, url = ToAbsolute(FaqPath) },
            new { @type = "SiteNavigationElement", name = L["PageTitle_Generator"].Value, url = ToAbsolute(GeneratorPath) }
        }
    });

    protected override async Task OnInitializedAsync()
    {
        HeroExperimentVariant = ExperimentService.ResolveVariant(HeroExperimentKey);
        ClusterPages = SeoLandingPageService.GetClusterPages(CurrentLanguage);
        var presets = await PresetService.GetAllAsync();
        TotalPresetCount = presets.Count;
        FeaturedPresets = presets
            .OrderByDescending(x => x.PopularityScore)
            .ThenBy(x => x.GetTitle(CurrentLanguage), StringComparer.CurrentCultureIgnoreCase)
            .Take(6)
            .ToList();
    }

    private string GetCategoryLabel(PresetCategory category)
        => CategoryLabelResolver.Resolve(category.ToString(), L);

    private string? GetCategoryLandingPath(PromptPreset preset)
        => SeoLandingPageService.GetCategoryLandingPath(CurrentLanguage, preset.Category);

    private static string GetClusterIcon(PresetCategory category)
        => category switch
        {
            PresetCategory.Business => "📊",
            PresetCategory.Marketing => "📣",
            PresetCategory.Coding => "⚙️",
            PresetCategory.Influencer => "🪝",
            PresetCategory.YouTube => "🎬",
            PresetCategory.ImageGeneration => "🎨",
            PresetCategory.Productivity => "✅",
            _ => "📚"
        };

    private string ToAbsolute(string relativePath)
    {
        var normalized = string.IsNullOrWhiteSpace(relativePath) ? "/" : relativePath;
        return new Uri(new Uri(Navigation.BaseUri), normalized).ToString();
    }
}

