@page "/de/{Slug}"
@page "/en/{Slug}"
@using System.Globalization
@using System.Text.Json
@using Microsoft.AspNetCore.Http
@inject IStringLocalizer<SharedResource> L
@inject ISeoLandingPageService SeoLandingPageService
@inject NavigationManager Navigation

@if (PageModel is null)
{
    <PageTitle>@L["PageTitle_NotFound"]</PageTitle>
    <HeadContent>
        <meta name="robots" content="noindex,nofollow,noarchive" />
    </HeadContent>

    <section class="py-5 text-center">
        <h1 class="h2 mb-3">@L["SeoLanding_NotFound_Title"]</h1>
        <p class="text-secondary mb-4">@L["SeoLanding_NotFound_Desc"]</p>
        <a class="btn btn-primary" href="@PresetsPath">@L["SeoLanding_NotFound_Cta"]</a>
    </section>
}
else
{
    <PageTitle>@PageModel.MetaTitle</PageTitle>
    <HeadContent>
        <meta name="application-name" content="PromptToMars" />
        <meta name="description" content="@PageModel.MetaDescription" />
        <meta name="robots" content="index,follow,max-image-preview:large" />
        <meta property="og:type" content="website" />
        <meta property="og:title" content="@PageModel.MetaTitle" />
        <meta property="og:description" content="@PageModel.MetaDescription" />
        <meta property="og:site_name" content="PromptToMars" />
        <meta property="og:url" content="@CanonicalUrl" />
        <meta property="og:locale" content="@(PageModel.Culture == "de" ? "de_DE" : "en_US")" />
        <meta property="og:locale:alternate" content="@(PageModel.Culture == "de" ? "en_US" : "de_DE")" />
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content="@PageModel.MetaTitle" />
        <meta name="twitter:description" content="@PageModel.MetaDescription" />
        <link rel="canonical" href="@CanonicalUrl" />
        <link rel="alternate" hreflang="de" href="@GermanUrl" />
        <link rel="alternate" hreflang="en" href="@EnglishUrl" />
        <link rel="alternate" hreflang="x-default" href="@EnglishUrl" />
        <script type="application/ld+json">@((MarkupString)WebPageJsonLd)</script>
        <script type="application/ld+json">@((MarkupString)BreadcrumbJsonLd)</script>
        <script type="application/ld+json">@((MarkupString)HowToJsonLd)</script>
        <script type="application/ld+json">@((MarkupString)RelatedContentJsonLd)</script>
        <script type="application/ld+json">@((MarkupString)ImageMetadataJsonLd)</script>
        @if (PageModel.FaqItems.Count > 0)
        {
            <script type="application/ld+json">@((MarkupString)FaqJsonLd)</script>
        }
    </HeadContent>

    <article class="seo-landing">
        <nav class="mb-3" aria-label="breadcrumb">
            <ol class="breadcrumb small mb-0">
                <li class="breadcrumb-item"><a href="@AppRoutes.HomePathForCulture(ActiveCulture)">PromptToMars</a></li>
                <li class="breadcrumb-item active" aria-current="page">@PageModel.MetaTitle</li>
            </ol>
        </nav>

        <section class="hero-section seo-hero rounded-4 p-4 p-lg-5 mb-5" aria-labelledby="seo-hero-title">
            <div class="row g-4 align-items-center">
                <div class="col-lg-9">
                    <span class="badge text-bg-primary mb-3">@PageModel.HeroBadge</span>
                    <h1 id="seo-hero-title" class="display-6 fw-bold mb-3">@PageModel.Headline</h1>
                    <p class="lead mb-0">@PageModel.Intro</p>
                </div>
                <div class="col-lg-3">
                    <div class="d-grid gap-2">
                        <a class="btn btn-primary"
                           href="@($"{GeneratorPath}?preset={PageModel.CtaPresetId}")"
                           data-track="seo.hero.generator"
                           data-track-context="@PageModel.Category">@PageModel.CtaGeneratorLabel</a>
                        <a class="btn btn-outline-secondary"
                           href="@PageModel.PresetsCategoryPath"
                           data-track="seo.hero.presets"
                           data-track-context="@PageModel.Category">@PageModel.CtaPresetsLabel</a>
                    </div>
                </div>
            </div>
        </section>

        <section class="mb-5" aria-labelledby="seo-workflow-title">
            <div class="card border-0 shadow-sm seo-workflow-card">
                <div class="card-body p-4 p-lg-5">
                    <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
                        <div>
                            <h2 id="seo-workflow-title" class="h3 mb-2">@LandingWorkflowTitle</h2>
                            <p class="text-secondary mb-0">@LandingWorkflowIntro</p>
                        </div>
                        <div class="d-flex flex-wrap gap-2">
                            <a class="btn btn-sm btn-primary" href="@($"{GeneratorPath}?preset={PageModel.CtaPresetId}")">@PageModel.CtaGeneratorLabel</a>
                            <a class="btn btn-sm btn-outline-secondary" href="@OptimizerPath">@LandingWorkflowOptimizerLabel</a>
                            <a class="btn btn-sm btn-outline-secondary" href="@FaqPath">@LandingWorkflowFaqLabel</a>
                        </div>
                    </div>
                    <ol class="mb-0">
                        @foreach (var step in LandingWorkflowSteps.Select((text, index) => new { text, index }))
                        {
                            <li id="@($"landing-step-{step.index + 1}")" class="mb-2">@step.text</li>
                        }
                    </ol>
                </div>
            </div>
        </section>

        <section class="mb-5" aria-labelledby="seo-benefits-title">
            <h2 id="seo-benefits-title" class="h3 mb-3">@PageModel.BenefitsTitle</h2>
            <div class="row g-3">
                @foreach (var benefit in PageModel.Benefits)
                {
                    <div class="col-md-6">
                        <div class="card border-0 shadow-sm h-100 seo-benefit-card">
                            <div class="card-body">
                                <p class="mb-0">@benefit</p>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </section>

        <section class="mb-5" aria-labelledby="seo-usecases-title">
            <h2 id="seo-usecases-title" class="h3 mb-3">@PageModel.UseCasesTitle</h2>
            <div class="row g-3">
                @foreach (var useCase in PageModel.UseCases)
                {
                    <div class="col-lg-6">
                        <div class="card border-0 shadow-sm h-100 seo-usecase-card">
                            <div class="card-body">
                                <h3 class="h6 text-primary mb-2">@(PageModel.Culture == "de" ? "Anwendungsfall" : "Use case")</h3>
                                <p class="mb-0">@useCase</p>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </section>

        <section class="mb-5" aria-labelledby="seo-presets-title">
            <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
                <h2 id="seo-presets-title" class="h3 mb-0">@PageModel.PresetExamplesTitle</h2>
                <a class="link-secondary text-decoration-none fw-semibold"
                   href="@PageModel.PresetsCategoryPath"
                   data-track="seo.presets.browse"
                   data-track-context="@PageModel.Category">@PageModel.ExploreCategoryPresetsLabel</a>
            </div>
            <div class="row g-3">
                @foreach (var preset in PageModel.PresetExamples)
                {
                    <div class="col-md-6 col-xl-3">
                        <div class="card border-0 shadow-sm h-100 seo-preset-card">
                            <div class="card-body d-flex flex-column">
                                <h3 class="h6">@preset.GetTitle(PageModel.Culture)</h3>
                                <p class="text-secondary small">@preset.GetDescription(PageModel.Culture)</p>
                                <a class="btn btn-sm btn-primary mt-auto"
                                   href="@($"{GeneratorPath}?preset={preset.Id}")"
                                   data-track="seo.presets.use"
                                   data-track-context="@PageModel.Category">@L["Presets_Action_UseThis"]</a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </section>

        <section class="mb-5" aria-labelledby="seo-examples-title">
            <h2 id="seo-examples-title" class="h3 mb-3">@PageModel.ExamplePromptsTitle</h2>
            <div class="row g-3">
                @foreach (var example in PageModel.ExamplePrompts)
                {
                    <div class="col-lg-4">
                        <div class="card border-0 shadow-sm h-100 seo-example-card">
                            <div class="card-body">
                                <pre class="history-prompt mb-0">@example</pre>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </section>

        @if (PageModel.RelatedPresets.Count > 0)
        {
            <section class="mb-5" aria-labelledby="seo-related-presets-title">
                <h2 id="seo-related-presets-title" class="h3 mb-3">@PageModel.RelatedPresetsTitle</h2>
                <div class="row g-3">
                    @foreach (var preset in PageModel.RelatedPresets)
                    {
                        <div class="col-md-6 col-xl-3">
                            <div class="card border-0 shadow-sm h-100 seo-related-preset-card">
                                <div class="card-body d-flex flex-column">
                                    <h3 class="h6">@preset.GetTitle(PageModel.Culture)</h3>
                                    <p class="small text-secondary">@preset.GetDescription(PageModel.Culture)</p>
                                    <a class="btn btn-sm btn-outline-primary mt-auto"
                                       href="@($"{GeneratorPath}?preset={preset.Id}")"
                                       data-track="seo.related_presets.use"
                                       data-track-context="@PageModel.Category">@L["Presets_Action_UseThis"]</a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </section>
        }

        @if (PageModel.RelatedPages.Count > 0)
        {
            <section class="mb-5" aria-labelledby="seo-related-pages-title">
                <h2 id="seo-related-pages-title" class="h3 mb-3">@PageModel.RelatedPagesTitle</h2>
                <div class="row g-3">
                    @foreach (var relatedPage in PageModel.RelatedPages)
                    {
                        <div class="col-md-6 col-xl-3">
                            <div class="card border-0 shadow-sm h-100 seo-related-page-card">
                                <div class="card-body d-flex flex-column">
                                    <h3 class="h6">@relatedPage.Title</h3>
                                    <p class="text-secondary small">@relatedPage.Description</p>
                                    <a class="btn btn-sm btn-outline-secondary mt-auto"
                                       href="@relatedPage.Path"
                                       data-track="seo.related_pages.open"
                                       data-track-context="@relatedPage.Category">@PageModel.RelatedPagesCtaLabel</a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </section>
        }

        <section class="mb-5" aria-labelledby="seo-tool-links-title">
            <div class="card border-0 shadow-sm seo-tool-links-card">
                <div class="card-body p-4 p-lg-5">
                    <h2 id="seo-tool-links-title" class="h3 mb-2">@ToolLinksTitle</h2>
                    <p class="text-secondary mb-3">@ToolLinksIntro</p>
                    <div class="d-flex flex-wrap gap-2 mb-3">
                        <a class="btn btn-outline-primary" href="@($"{GeneratorPath}?preset={PageModel.CtaPresetId}")">@PageModel.CtaGeneratorLabel</a>
                        <a class="btn btn-outline-secondary" href="@PageModel.PresetsCategoryPath">@PageModel.CtaPresetsLabel</a>
                        <a class="btn btn-outline-secondary" href="@OptimizerPath">@ToolLinksOptimizerLabel</a>
                        <a class="btn btn-outline-secondary" href="@FaqPath">@ToolLinksFaqLabel</a>
                    </div>
                    @if (PageModel.RelatedPages.Count > 0)
                    {
                        <div class="small text-secondary mb-2 fw-semibold">@ToolLinksClusterLabel</div>
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var relatedPage in PageModel.RelatedPages.Take(4))
                            {
                                <a class="btn btn-sm btn-outline-secondary" href="@relatedPage.Path">@relatedPage.Title</a>
                            }
                        </div>
                    }
                </div>
            </div>
        </section>

        @if (PageModel.FaqItems.Count > 0)
        {
            <section class="mb-5" aria-labelledby="seo-faq-title">
                <h2 id="seo-faq-title" class="h3 mb-3">@PageModel.FaqTitle</h2>
                <div class="accordion seo-faq-accordion" id="faq-accordion">
                    @for (var index = 0; index < PageModel.FaqItems.Count; index++)
                    {
                        var faq = PageModel.FaqItems[index];
                        var headingId = $"faq-heading-{index}";
                        var collapseId = $"faq-collapse-{index}";

                        <div class="accordion-item">
                            <h3 class="accordion-header" id="@headingId">
                                <button class="accordion-button @(index == 0 ? string.Empty : "collapsed")" type="button" data-bs-toggle="collapse" data-bs-target="@($"#{collapseId}")" aria-expanded="@(index == 0)" aria-controls="@collapseId">
                                    @faq.Question
                                </button>
                            </h3>
                            <div id="@collapseId" class="accordion-collapse collapse @(index == 0 ? "show" : string.Empty)" aria-labelledby="@headingId" data-bs-parent="#faq-accordion">
                                <div class="accordion-body text-secondary">@faq.Answer</div>
                            </div>
                        </div>
                    }
                </div>
            </section>
        }

        <section class="mb-2">
            <div class="card border-0 shadow-sm seo-cta-card">
                <div class="card-body p-4 p-lg-5">
                    <h2 class="h3 mb-2">@PageModel.CtaTitle</h2>
                    <p class="text-secondary mb-4">@PageModel.CtaSubtitle</p>
                    <div class="d-flex flex-wrap gap-2">
                        <a class="btn btn-primary btn-lg"
                           href="@($"{GeneratorPath}?preset={PageModel.CtaPresetId}")"
                           data-track="seo.cta.generator"
                           data-track-context="@PageModel.Category">@PageModel.CtaGeneratorLabel</a>
                        <a class="btn btn-outline-secondary btn-lg"
                           href="@PageModel.PresetsCategoryPath"
                           data-track="seo.cta.presets"
                           data-track-context="@PageModel.Category">@PageModel.CtaPresetsLabel</a>
                    </div>
                </div>
            </div>
        </section>
    </article>
}

@code {
    [Parameter]
    public string Slug { get; set; } = string.Empty;

    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private SeoLandingPageViewModel? PageModel { get; set; }

    private string CanonicalUrl => ToAbsolute(PageModel?.CanonicalPath ?? string.Empty);
    private string GermanUrl => ToAbsolute(PageModel?.AlternatePathDe ?? string.Empty);
    private string EnglishUrl => ToAbsolute(PageModel?.AlternatePathEn ?? string.Empty);
    private string ActiveCulture => PageModel?.Culture ?? ResolveRouteCulture();
    private string GeneratorPath => AppRoutes.GeneratorPathForCulture(ActiveCulture);
    private string OptimizerPath => AppRoutes.OptimizerPathForCulture(ActiveCulture);
    private string FaqPath => AppRoutes.FaqPathForCulture(ActiveCulture);
    private string PresetsPath => AppRoutes.PresetsPathForCulture(ActiveCulture);
    private string LicenseUrl => ToAbsolute(AppRoutes.LicensePathForCulture(ActiveCulture));
    private string AcquireLicenseUrl => $"{LicenseUrl}#acquire";
    private string SiteImageUrl => ToAbsolute("/favicon.png");
    private string LandingWorkflowTitle => ActiveCulture == "de" ? "So nutzt du diese Landingpage effektiv" : "How to use this landing page effectively";
    private string LandingWorkflowIntro => ActiveCulture == "de"
        ? "Nutze die Themenseite als Einstieg, wechsle dann in Presets und Generator und verfeinere den finalen Prompt im Optimizer."
        : "Use this topic page as your entry point, move into presets and the generator, and refine the final prompt in the optimizer.";
    private IReadOnlyList<string> LandingWorkflowSteps => ActiveCulture == "de"
        ?
        [
            $"Starte mit den Beispielen und Anwendungsfällen auf dieser Seite, um das Thema {PageModel?.Headline ?? string.Empty} schneller einzuordnen.",
            "Öffne ein passendes Preset und übernimm es direkt in den Generator, um Ziel, Rolle und Ausgabeformat anzupassen.",
            "Nutze danach den Prompt Optimizer, um Struktur, Klarheit und Qualitätsregeln weiter zu schärfen."
        ]
        :
        [
            $"Start with the examples and use cases on this page to understand the topic behind {PageModel?.Headline ?? string.Empty} more quickly.",
            "Open a matching preset and move it into the generator to adjust objective, role, and output format.",
            "Then use the prompt optimizer to further improve structure, clarity, and quality constraints."
        ];
    private string LandingWorkflowOptimizerLabel => ActiveCulture == "de" ? "Optimizer öffnen" : "Open optimizer";
    private string LandingWorkflowFaqLabel => ActiveCulture == "de" ? "FAQ lesen" : "Read FAQ";
    private string ToolLinksTitle => ActiveCulture == "de" ? "Nächste sinnvolle Schritte" : "Useful next steps";
    private string ToolLinksIntro => ActiveCulture == "de"
        ? "Diese internen Links helfen dir, vom informativen Einstieg direkt in passende Presets, Tools und angrenzende Themencluster zu wechseln."
        : "These internal links help you move from this informational entry page directly into matching presets, tools, and adjacent topic clusters.";
    private string ToolLinksOptimizerLabel => ActiveCulture == "de" ? "Prompt Optimizer" : "Prompt optimizer";
    private string ToolLinksFaqLabel => ActiveCulture == "de" ? "FAQ" : "FAQ";
    private string ToolLinksClusterLabel => ActiveCulture == "de" ? "Weitere thematisch passende Landingpages" : "More related landing pages";
    private string WebPageJsonLd => JsonSerializer.Serialize(new
    {
        @context = "https://schema.org",
        @type = "WebPage",
        name = PageModel?.MetaTitle ?? string.Empty,
        description = PageModel?.MetaDescription ?? string.Empty,
        inLanguage = PageModel?.Culture ?? "de",
        url = CanonicalUrl,
        isPartOf = new
        {
            @type = "WebSite",
            name = "PromptToMars",
            url = ToAbsolute("/")
        }
    });
    private string BreadcrumbJsonLd => JsonSerializer.Serialize(new
    {
        @context = "https://schema.org",
        @type = "BreadcrumbList",
        itemListElement = new object[]
        {
            new
            {
                @type = "ListItem",
                position = 1,
                name = "PromptToMars",
                item = ToAbsolute(AppRoutes.HomePathForCulture(ActiveCulture))
            },
            new
            {
                @type = "ListItem",
                position = 2,
                name = PageModel?.MetaTitle ?? string.Empty,
                item = CanonicalUrl
            }
        }
    });
    private string HowToJsonLd => JsonSerializer.Serialize(new
    {
        @context = "https://schema.org",
        @type = "HowTo",
        name = LandingWorkflowTitle,
        description = LandingWorkflowIntro,
        inLanguage = ActiveCulture,
        step = LandingWorkflowSteps
            .Select((step, index) => new
            {
                @type = "HowToStep",
                position = index + 1,
                name = step,
                text = step,
                url = CanonicalUrl + $"#landing-step-{index + 1}"
            })
            .ToArray()
    });
    private string FaqJsonLd => JsonSerializer.Serialize(new
    {
        @context = "https://schema.org",
        @type = "FAQPage",
        mainEntity = (PageModel?.FaqItems.Select(x => new
        {
            @type = "Question",
            name = x.Question,
            acceptedAnswer = new
            {
                @type = "Answer",
                text = x.Answer
            }
        }).ToArray()) ?? Array.Empty<object>()
    });
    private string ImageMetadataJsonLd => JsonSerializer.Serialize(new
    {
        @context = "https://schema.org",
        @type = "ImageObject",
        contentUrl = SiteImageUrl,
        url = SiteImageUrl,
        creditText = "PromptToMars",
        acquireLicensePage = AcquireLicenseUrl,
        license = LicenseUrl,
        copyrightNotice = $"© {DateTime.UtcNow.Year} PromptToMars"
    });
    private string RelatedContentJsonLd => JsonSerializer.Serialize(new
    {
        @context = "https://schema.org",
        @graph = new object[]
        {
            new
            {
                @type = "CollectionPage",
                name = PageModel?.MetaTitle ?? string.Empty,
                description = PageModel?.MetaDescription ?? string.Empty,
                url = CanonicalUrl,
                inLanguage = PageModel?.Culture ?? "de"
            },
            new
            {
                @type = "ItemList",
                name = PageModel?.RelatedPagesTitle ?? string.Empty,
                itemListElement = (PageModel?.RelatedPages.Select((page, index) => new
                {
                    @type = "ListItem",
                    position = index + 1,
                    name = page.Title,
                    url = ToAbsolute(page.Path)
                }).ToArray()) ?? Array.Empty<object>()
            },
            new
            {
                @type = "ItemList",
                name = PageModel?.PresetExamplesTitle ?? string.Empty,
                itemListElement = (PageModel?.PresetExamples.Select((preset, index) => new
                {
                    @type = "ListItem",
                    position = index + 1,
                    name = preset.GetTitle(ActiveCulture),
                    url = ToAbsolute($"{GeneratorPath}?preset={preset.Id}")
                }).ToArray()) ?? Array.Empty<object>()
            }
        }
    });

    protected override async Task OnParametersSetAsync()
    {
        var culture = ResolveRouteCulture();
        PageModel = await SeoLandingPageService.GetBySlugAsync(culture, Slug);

        if (HttpContext is null)
        {
            return;
        }

        HttpContext.Response.StatusCode = PageModel is null
            ? StatusCodes.Status404NotFound
            : StatusCodes.Status200OK;
    }

    private string ResolveRouteCulture()
    {
        var relativePath = Navigation.ToBaseRelativePath(Navigation.Uri);
        var firstSegment = relativePath.Split('/', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault();
        return firstSegment?.Equals("de", StringComparison.OrdinalIgnoreCase) == true ? "de" : "en";
    }

    private string ToAbsolute(string relativePath)
    {
        var normalized = string.IsNullOrWhiteSpace(relativePath) ? "/" : relativePath;
        return new Uri(new Uri(Navigation.BaseUri), normalized).ToString();
    }
}

