    {
        if (SelectedPlatformOption.Equals(CustomPlatformOptionValue, StringComparison.Ordinal))
        {
            return;
        }

        Request.Platform = SelectedPlatformOption;
    }

    private void OnMainCategoryChanged()
    {
        SyncSubcategorySelection(forceDefaultIfOutOfScope: true);
        SyncTargetAudienceSelection();
        SyncRoleSelection();
    }

    private void OnSubcategoryOptionChanged()
