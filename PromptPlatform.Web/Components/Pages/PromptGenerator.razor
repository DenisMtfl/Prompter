    private void SyncAllSelections()
    {
        SyncPlatformSelection();
        SyncSubcategorySelection();
        SyncTargetAudienceSelection();
        SyncRoleSelection();
    }

    private void SyncPlatformSelection()
    {
        if (string.IsNullOrWhiteSpace(Request.Platform))
        {
            Request.Platform = AiProviderCatalog.TopProviders[0];
            SelectedPlatformOption = AiProviderCatalog.TopProviders[0];
            return;
        }

        var match = AiProviderCatalog.TopProviders.FirstOrDefault(x => x.Equals(Request.Platform, StringComparison.OrdinalIgnoreCase));
        if (match is null)
        {
            SelectedPlatformOption = CustomPlatformOptionValue;
            return;
        }

        SelectedPlatformOption = match;
        Request.Platform = match;
    }

    private void SyncSubcategorySelection(bool forceDefaultIfOutOfScope = false)
    {
        if (string.IsNullOrWhiteSpace(Request.Subcategory))
        {
            Request.Subcategory = AvailableSubcategoryOptions[0];
            SelectedSubcategoryOption = AvailableSubcategoryOptions[0];
            return;
        }

        var match = AvailableSubcategoryOptions.FirstOrDefault(x => x.Equals(Request.Subcategory, StringComparison.CurrentCultureIgnoreCase));
        if (match is null)
        {
            if (forceDefaultIfOutOfScope && !SelectedSubcategoryOption.Equals(CustomSubcategoryOptionValue, StringComparison.Ordinal))
            {
                Request.Subcategory = AvailableSubcategoryOptions[0];
                SelectedSubcategoryOption = AvailableSubcategoryOptions[0];
                return;
            }

            SelectedSubcategoryOption = CustomSubcategoryOptionValue;
            return;
        }

        SelectedSubcategoryOption = match;
        Request.Subcategory = match;
    }

    private void SyncTargetAudienceSelection()
    {
        if (string.IsNullOrWhiteSpace(Request.TargetAudience))
        {
            Request.TargetAudience = AvailableTargetAudienceOptions[0];
            SelectedTargetAudienceOption = AvailableTargetAudienceOptions[0];
            return;
        }

        var match = AvailableTargetAudienceOptions.FirstOrDefault(x => x.Equals(Request.TargetAudience, StringComparison.CurrentCultureIgnoreCase));
        if (match is null)
        {
            SelectedTargetAudienceOption = CustomTargetAudienceOptionValue;
            return;
        }

        SelectedTargetAudienceOption = match;
        Request.TargetAudience = match;
    }

    private void SyncRoleSelection()
    {
        if (string.IsNullOrWhiteSpace(Request.RolePerspective))
        {
            Request.RolePerspective = AvailableRoleOptions[0];
            SelectedRoleOption = AvailableRoleOptions[0];
            return;
