@page "/favorites"
@page "/de/favorites"
@page "/en/favorites"
@using System.Globalization
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["PageTitle_Favorites"]</PageTitle>
<HeadContent>
    <meta name="robots" content="noindex,nofollow,noarchive" />
</HeadContent>

<section class="py-4">
    <h1 class="h3 mb-2">@RemovedTitle</h1>
    <p class="text-secondary mb-4">@RemovedDescription</p>
    <div class="d-flex gap-2 flex-wrap">
        <a class="btn btn-primary" href="@AppRoutes.PresetsPathForCulture(CurrentLanguage)">@OpenPresetsLabel</a>
        <a class="btn btn-outline-secondary" href="@AppRoutes.GeneratorPathForCulture(CurrentLanguage)">@OpenGeneratorLabel</a>
    </div>
</section>

@code {
    private string CurrentLanguage => CultureInfo.CurrentUICulture.TwoLetterISOLanguageName.Equals("de", StringComparison.OrdinalIgnoreCase)
        ? "de"
        : "en";

    private bool IsGerman => CurrentLanguage == "de";
    private string RemovedTitle => IsGerman ? "Favoriten wurden entfernt" : "Favorites were removed";
    private string RemovedDescription => IsGerman
        ? "Diese Funktion ist aktuell nicht mehr Teil der Plattform."
        : "This feature is currently no longer part of the platform.";
    private string OpenPresetsLabel => IsGerman ? "Zur Preset-Bibliothek" : "Open preset library";
    private string OpenGeneratorLabel => IsGerman ? "Zum Generator" : "Open generator";
}

