    protected override void OnInitialized()
    {
        RelatedPages = SeoLandingPageService.GetClusterPages(CurrentLanguage)
            .Take(8)
            .ToList();
    }

    private string ToAbsolute(string relativePath)
    {
        var normalized = string.IsNullOrWhiteSpace(relativePath) ? "/" : relativePath;
        return new Uri(new Uri(Navigation.BaseUri), normalized).ToString();
    }

    private sealed record LocalizedText(string De, string En)
    {
        public string For(string language)
            => language.Equals("de", StringComparison.OrdinalIgnoreCase) ? De : En;
    }

    private sealed record FaqItem(LocalizedText Question, LocalizedText Answer);

    private sealed record FaqSection(
        string Key,
        LocalizedText Title,
        LocalizedText Intro,
        IReadOnlyList<FaqItem> Items);
}
