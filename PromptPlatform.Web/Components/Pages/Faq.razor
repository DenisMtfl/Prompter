    private string FaqJsonLd => JsonSerializer.Serialize(new
    {
        @context = "https://schema.org",
        @type = "FAQPage",
        mainEntity = Sections
            .SelectMany(section => section.Items)
            .Select(item => new
            {
                @type = "Question",
