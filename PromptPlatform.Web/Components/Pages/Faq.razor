                acceptedAnswer = new
                {
                    @type = "Answer",
                    text = item.Answer.For(CurrentLanguage)
                }
            })
            .ToArray()
    });

    private string BreadcrumbJsonLd => JsonSerializer.Serialize(new
    {
        @context = "https://schema.org",
        @type = "BreadcrumbList",
        itemListElement = new object[]
        {
            new
