@page "/faq"
@page "/de/faq"
@page "/en/faq"
@using System.Globalization
@using System.Text.Json
@inject NavigationManager Navigation
@inject ISeoLandingPageService SeoLandingPageService

<PageTitle>@PageTitle</PageTitle>
<HeadContent>
    <meta name="application-name" content="PromptForge" />
    <meta name="description" content="@MetaDescription" />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="@PageTitle" />
    <meta property="og:description" content="@MetaDescription" />
    <meta property="og:site_name" content="PromptForge" />
    <meta property="og:url" content="@CanonicalUrl" />
    <meta property="og:locale" content="@(IsGerman ? "de_DE" : "en_US")" />
    <meta property="og:locale:alternate" content="@(IsGerman ? "en_US" : "de_DE")" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@PageTitle" />
    <meta name="twitter:description" content="@MetaDescription" />
    <link rel="canonical" href="@CanonicalUrl" />
    <link rel="alternate" hreflang="de" href="@GermanUrl" />
    <link rel="alternate" hreflang="en" href="@EnglishUrl" />
    <link rel="alternate" hreflang="x-default" href="@EnglishUrl" />
    <script type="application/ld+json">@((MarkupString)FaqJsonLd)</script>
    <script type="application/ld+json">@((MarkupString)BreadcrumbJsonLd)</script>
    <script type="application/ld+json">@((MarkupString)FaqPageJsonLd)</script>
    <script type="application/ld+json">@((MarkupString)ImageMetadataJsonLd)</script>
</HeadContent>

<article class="faq-page">
    <nav class="mb-3" aria-label="breadcrumb">
        <ol class="breadcrumb small mb-0">
            <li class="breadcrumb-item"><a href="@AppRoutes.HomePathForCulture(CurrentLanguage)">PromptForge</a></li>
            <li class="breadcrumb-item active" aria-current="page">FAQ</li>
        </ol>
    </nav>

    <section class="hero-section faq-hero rounded-4 p-4 p-lg-5 mb-4">
        <div class="row g-4 align-items-center">
            <div class="col-lg-8">
                <span class="badge text-bg-primary mb-3">@HeroBadge</span>
                <h1 class="display-6 fw-bold mb-3">@HeroTitle</h1>
                <p class="lead mb-0">@HeroSubtitle</p>
            </div>
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm faq-hero-actions-card h-100">
                    <div class="card-body d-grid gap-2">
                        <a class="btn btn-primary" href="@GeneratorPath">@GeneratorCta</a>
                        <a class="btn btn-outline-secondary" href="@PresetsPath">@PresetsCta</a>
                        <a class="btn btn-outline-secondary" href="@OptimizerPath">@OptimizerCta</a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="mb-5">
        <div class="card border-0 shadow-sm faq-nav-card">
            <div class="card-body">
                <h2 class="h4 mb-3">@QuickNavTitle</h2>
                <div class="row g-2">
                    @foreach (var faqSection in Sections)
                    {
                        <div class="col-md-6 col-xl-4">
                            <a class="btn btn-outline-secondary w-100 text-start faq-nav-link" href="@($"#faq-{faqSection.Key}")">@faqSection.Title.For(CurrentLanguage)</a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </section>

    @foreach (var faqSection in Sections)
    {
        var accordionId = $"faq-accordion-{faqSection.Key}";
        <section id="@($"faq-{faqSection.Key}")" class="mb-5 faq-section">
            <div class="mb-3">
                <h2 class="h3 mb-2">@faqSection.Title.For(CurrentLanguage)</h2>
                <p class="text-secondary mb-0">@faqSection.Intro.For(CurrentLanguage)</p>
            </div>

            <div class="accordion faq-accordion" id="@accordionId">
                @for (var i = 0; i < faqSection.Items.Count; i++)
                {
                    var item = faqSection.Items[i];
                    var headingId = $"{faqSection.Key}-heading-{i}";
                    var collapseId = $"{faqSection.Key}-collapse-{i}";
                    <div class="accordion-item">
                        <h3 class="accordion-header" id="@headingId">
                            <button class="accordion-button @(i == 0 ? string.Empty : "collapsed")"
                                    type="button"
                                    data-bs-toggle="collapse"
                                    data-bs-target="@($"#{collapseId}")"
                                    aria-expanded="@(i == 0)"
                                    aria-controls="@collapseId">
                                @item.Question.For(CurrentLanguage)
                            </button>
                        </h3>
                        <div id="@collapseId"
                             class="accordion-collapse collapse @(i == 0 ? "show" : string.Empty)"
                             aria-labelledby="@headingId"
                             data-bs-parent="@($"#{accordionId}")">
                            <div class="accordion-body text-secondary">
                                @item.Answer.For(CurrentLanguage)
                            </div>
                        </div>
                    </div>
                }
            </div>
        </section>
    }

    <section class="faq-related-section">
        <div class="card border-0 shadow-sm faq-related-card">
            <div class="card-body p-4 p-lg-5">
                <h2 class="h3 mb-2">@RelatedTitle</h2>
                <p class="text-secondary mb-3">@RelatedSubtitle</p>

                <div class="d-flex flex-wrap gap-2 mb-4">
                    @foreach (var relatedPage in RelatedPages)
                    {
                        <a class="btn btn-sm btn-outline-secondary" href="@relatedPage.Path">@relatedPage.Title</a>
                    }
                </div>

                <div class="d-flex flex-wrap gap-2">
                    <a class="btn btn-primary btn-lg" href="@GeneratorPath">@GeneratorCta</a>
                    <a class="btn btn-outline-secondary btn-lg" href="@PresetsPath">@PresetsCta</a>
                </div>
            </div>
        </div>
    </section>
</article>

