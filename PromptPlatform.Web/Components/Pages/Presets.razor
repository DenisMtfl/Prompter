@page "/presets"
@page "/prompt-presets"
@page "/de/presets"
@page "/en/presets"
@implements IAsyncDisposable
@using System.Globalization
@using System.Text.Json
@inject IStringLocalizer<SharedResource> L
@inject IPresetService PresetService
@inject ISeoLandingPageService SeoLandingPageService
@inject IJSRuntime JsRuntime
@inject NavigationManager Navigation

<PageTitle>@PresetsTitle</PageTitle>
<HeadContent>
    <meta name="application-name" content="PrompToMars" />
    <meta name="description" content="@PresetsMetaDescription" />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="@PresetsTitle" />
    <meta property="og:description" content="@PresetsMetaDescription" />
    <meta property="og:site_name" content="PrompToMars" />
    <meta property="og:url" content="@CanonicalUrl" />
    <meta property="og:locale" content="@(IsGerman ? "de_DE" : "en_US")" />
    <meta property="og:locale:alternate" content="@(IsGerman ? "en_US" : "de_DE")" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@PresetsTitle" />
    <meta name="twitter:description" content="@PresetsMetaDescription" />
    <link rel="canonical" href="@CanonicalUrl" />
    <link rel="alternate" hreflang="de" href="@GermanUrl" />
    <link rel="alternate" hreflang="en" href="@EnglishUrl" />
    <link rel="alternate" hreflang="x-default" href="@EnglishUrl" />
    <script type="application/ld+json">@((MarkupString)PresetsJsonLd)</script>
    <script type="application/ld+json">@((MarkupString)PresetDiscoveryJsonLd)</script>
    <script type="application/ld+json">@((MarkupString)ImageMetadataJsonLd)</script>
</HeadContent>

<nav class="mb-3" aria-label="breadcrumb">
    <ol class="breadcrumb small mb-0">
        <li class="breadcrumb-item"><a href="@AppRoutes.HomePathForCulture(CurrentLanguage)">PrompToMars</a></li>
        <li class="breadcrumb-item active" aria-current="page">@PresetsTitle</li>
    </ol>
</nav>

<section class="mb-4">
    <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
        <h1 class="h3 mb-0">@L["Presets_Title"]</h1>
        @if (TotalPresetLibraryCount > 0)
        {
            <span class="preset-library-count-badge">@PresetLibraryCountLabel</span>
        }
    </div>
    <p class="text-secondary mb-0">@L["Presets_Subtitle"]</p>
</section>

<section class="mb-4" aria-labelledby="preset-cluster-nav">
    <div class="card border-0 shadow-sm preset-cluster-nav-card">
        <div class="card-body">
            <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
                <h2 id="preset-cluster-nav" class="h5 mb-0">@ClusterNavigationTitle</h2>
                <a class="link-secondary text-decoration-none fw-semibold"
                   href="@GeneratorPath"
                   data-track="presets.cluster.generator"
                   data-track-context="@CurrentLanguage">@ClusterNavigationCta</a>
            </div>
            <div class="d-flex flex-wrap gap-2">
                @foreach (var clusterPage in ClusterPages)
                {
                    <a class="btn btn-sm btn-outline-secondary"
                       href="@clusterPage.Path"
                       data-track="presets.cluster.page"
                       data-track-context="@clusterPage.Category">@clusterPage.Title</a>
                }
            </div>
        </div>
    </div>
</section>

<div class="card border-0 shadow-sm mb-4 preset-filter-card">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-xl-4">
                <label class="form-label">@L["Presets_Search"]</label>
                <input class="form-control" @bind="SearchText" @bind:after="OnFilterChanged" placeholder="@SearchPlaceholder" />
            </div>
            <div class="col-sm-6 col-xl-2">
                <label class="form-label">@MainCategoryLabel</label>
                <select class="form-select" @bind="CategoryFilter" @bind:after="OnCategoryChanged">
                    <option value="all">@AllLabel</option>
                    @foreach (var category in Enum.GetValues<PresetCategory>())
                    {
                        <option value="@category">@GetCategoryLabel(category)</option>
                    }
                </select>
            </div>
            <div class="col-sm-6 col-xl-2">
                <label class="form-label">@SubcategoryLabel</label>
                <select class="form-select" @bind="SubcategoryFilter" @bind:after="OnFilterChanged">
                    <option value="all">@AllLabel</option>
                    @foreach (var subcategory in AvailableSubcategories)
                    {
                        <option value="@subcategory">@subcategory</option>
                    }
                </select>
            </div>
            <div class="col-sm-6 col-xl-2">
                <label class="form-label">@PlatformLabel</label>
                <select class="form-select" @bind="PlatformFilter" @bind:after="OnFilterChanged">
                    <option value="all">@AllLabel</option>
                    @foreach (var platform in AvailablePlatforms)
                    {
                        <option value="@platform">@platform</option>
                    }
                </select>
            </div>
        </div>

        <div class="row g-3 mt-1 align-items-end">
            <div class="col-sm-6 col-xl-3">
                <label class="form-label">@SortLabel</label>
                <select class="form-select" @bind="SortFilter" @bind:after="OnFilterChanged">
                    <option value="relevance">@SortRelevanceLabel</option>
                    <option value="popularity">@SortPopularityLabel</option>
                    <option value="title">@SortTitleLabel</option>
                </select>
            </div>
            <div class="col-xl-9">
                <div class="w-100 text-xl-end text-secondary small fw-semibold pt-2">
                    @L["Presets_Count", TotalFilteredPresetCount]
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 preset-grid">
    @if (TotalFilteredPresetCount == 0)
    {
        <div class="col-12">
            <div class="alert alert-secondary">@L["Presets_Empty"]</div>
        </div>
    }
    else
    {
        @foreach (var preset in VisiblePresets)
        {
            var landingPath = GetCategoryLandingPath(preset.Category);
            var title = GetTitle(preset);
            var description = GetDescription(preset);
            var subcategory = GetSubcategory(preset);
            var tags = GetTags(preset);

            <div class="col-md-6 col-xxl-4 d-flex">
                <div class="card h-100 border-0 shadow-sm preset-card w-100">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                            <h3 class="h5 mb-0">@title</h3>
                            <span class="badge rounded-pill text-bg-light border preset-chip">@GetCategoryLabel(preset.Category)</span>
                        </div>

                        <p class="text-secondary mb-2">@description</p>

                        <div class="preset-meta small text-secondary mb-2">
                            <div><strong>@SubcategoryLabel:</strong> @subcategory</div>
                            <div><strong>@PlatformLabel:</strong> @preset.DefaultPlatform</div>
                            <div><strong>@ComplexityLabel:</strong> @L[$"Complexity_{preset.DefaultComplexityLevel}"]</div>
                        </div>

                        @if (tags.Count > 0)
                        {
                            <div class="preset-tag-list mb-3">
                                @foreach (var tag in tags.Take(6))
                                {
                                    <span class="badge rounded-pill text-bg-light border me-1 mb-1">@tag</span>
                                }
                            </div>
                        }

                        <div class="small text-secondary mb-2 fw-semibold">@ExampleInputLabel</div>
                        <pre class="history-prompt preset-example-input mb-3">@GetExampleInput(preset)</pre>

                        <div class="small text-secondary mb-2 fw-semibold">@L["Presets_ExamplePrompt"]</div>
                        <pre class="history-prompt preset-example mb-3">@GetExamplePrompt(preset)</pre>

                        <div class="d-flex gap-2 mt-auto flex-wrap">
                                <a class="btn btn-primary btn-sm"
                                   href="@AppRoutes.PromptPathForPreset(preset.Slug)"
                               data-track="presets.use"
                               data-track-context="@preset.Category">@UsePresetLabel</a>
                            @if (!string.IsNullOrWhiteSpace(landingPath))
                            {
                                <a class="btn btn-outline-secondary btn-sm"
                                   href="@landingPath"
                                   data-track="presets.open_landing"
                                   data-track-context="@preset.Category">@CategoryLandingLabel</a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>

@if (HasMorePresetsToLoad)
{
    <div class="d-flex justify-content-center py-4">
        @if (IsLoadingMorePresets)
        {
            <div class="preset-load-status">@LoadingMoreLabel</div>
        }
    </div>
    <div @ref="PresetLoadSentinel" class="preset-scroll-sentinel" aria-hidden="true"></div>
}

@code {
    [SupplyParameterFromQuery(Name = "category")]
    public string? Category { get; set; }

    private IReadOnlyList<PromptPreset> PresetsCollection { get; set; } = [];
    private IReadOnlyList<SeoLandingPageLinkViewModel> ClusterPages { get; set; } = [];

    private string SearchText { get; set; } = string.Empty;
    private string CategoryFilter { get; set; } = "all";
    private string SubcategoryFilter { get; set; } = "all";
    private string PlatformFilter { get; set; } = "all";
    private string SortFilter { get; set; } = "relevance";

    private string? LastAppliedCategoryQuery { get; set; }
    private string LastFilterSignature { get; set; } = string.Empty;
    private IReadOnlyList<PromptPreset> CachedFilteredPresets { get; set; } = [];
    private int VisiblePresetCount { get; set; } = InitialPresetBatchSize;
    private ElementReference PresetLoadSentinel;
    private DotNetObjectReference<Presets>? DotNetReference { get; set; }
    private bool IsObserverAttached { get; set; }
    private bool ObserverRefreshPending { get; set; } = true;
    private bool IsLoadingMorePresets { get; set; }

    private const int InitialPresetBatchSize = 36;
    private const int PresetBatchSize = 24;
    private const string PresetScrollObserverKey = "presets-grid";

    private string CurrentLanguage => CultureInfo.CurrentUICulture.TwoLetterISOLanguageName.Equals("de", StringComparison.OrdinalIgnoreCase)
        ? "de"
        : "en";

    private bool IsGerman => CurrentLanguage == "de";
    private string ActiveContentLanguage => CurrentLanguage;

    private string ClusterNavigationTitle => IsGerman ? "Themencluster und Landingpages" : "Topic clusters and landing pages";
    private string ClusterNavigationCta => IsGerman ? "Direkt zum Generator" : "Open generator";
    private string SearchPlaceholder => IsGerman ? "Titel, Beschreibung oder Tags durchsuchen" : "Search title, description, or tags";
    private string MainCategoryLabel => IsGerman ? "Hauptbereich" : "Main area";
    private string SubcategoryLabel => IsGerman ? "Unterkategorie" : "Subcategory";
    private string PlatformLabel => IsGerman ? "Plattform" : "Platform";
    private string SortLabel => IsGerman ? "Sortierung" : "Sort";
    private string SortRelevanceLabel => IsGerman ? "Relevanz" : "Relevance";
    private string SortPopularityLabel => IsGerman ? "Beliebtheit" : "Popularity";
    private string SortTitleLabel => IsGerman ? "Titel" : "Title";
    private string AllLabel => IsGerman ? "Alle" : "All";
    private string UsePresetLabel => IsGerman ? "Preset nutzen" : "Use preset";
    private string CategoryLandingLabel => IsGerman ? "Zur Landingpage" : "Open landing page";
    private string ExampleInputLabel => IsGerman ? "Beispiel-Eingabe" : "Example input";
    private string ComplexityLabel => IsGerman ? "Komplexität" : "Complexity";
    private string LoadingMoreLabel => IsGerman ? "Weitere Presets werden geladen..." : "Loading more presets...";
    private string PresetsTitle => IsGerman
        ? "KI Prompt Presets, Vorlagen, Beispiele & Shareable Prompts | PrompToMars"
        : "AI Prompt Presets, Templates, Examples & Shareable Prompts | PrompToMars";
    private string PresetsMetaDescription => IsGerman
        ? "Durchsuchbare Bibliothek für KI Prompt Presets, Vorlagen und Beispiele mit Filtern nach Kategorie, Plattform und Unterkategorie, teilbaren Prompt-Links und direkter Generator-Übernahme."
        : "Searchable library of AI prompt presets, templates, and examples with filters by category, platform, and subcategory, shareable prompt links, and direct generator handoff.";
    private string GeneratorPath => AppRoutes.GeneratorPathForCulture(CurrentLanguage);
    private string LocalizedPresetsPath => AppRoutes.PresetsPathForCulture(CurrentLanguage);
    private string CanonicalUrl => ToAbsolute(LocalizedPresetsPath);
    private string GermanUrl => ToAbsolute(AppRoutes.PresetsPathForCulture("de"));
    private string EnglishUrl => ToAbsolute(AppRoutes.PresetsPathForCulture("en"));
    private string LicenseUrl => ToAbsolute(AppRoutes.LicensePathForCulture(CurrentLanguage));
    private string AcquireLicenseUrl => $"{LicenseUrl}#acquire";
    private string SiteImageUrl => ToAbsolute("/favicon.png");
    private string ImageMetadataJsonLd => JsonSerializer.Serialize(new
    {
        @context = "https://schema.org",
        @type = "ImageObject",
        contentUrl = SiteImageUrl,
        url = SiteImageUrl,
        creditText = "PrompToMars",
        acquireLicensePage = AcquireLicenseUrl,
        license = LicenseUrl,
        copyrightNotice = $"© {DateTime.UtcNow.Year} PrompToMars"
    });
    private string PresetsJsonLd => JsonSerializer.Serialize(new
    {
        @context = "https://schema.org",
        @graph = new object[]
        {
            new
            {
                @type = "CollectionPage",
                name = PresetsTitle,
                description = PresetsMetaDescription,
                url = CanonicalUrl,
                inLanguage = CurrentLanguage
            },
            new
            {
                @type = "BreadcrumbList",
                itemListElement = new object[]
                {
                    new { @type = "ListItem", position = 1, name = "PrompToMars", item = ToAbsolute(AppRoutes.HomePathForCulture(CurrentLanguage)) },
                    new { @type = "ListItem", position = 2, name = PresetsTitle, item = CanonicalUrl }
                }
            }
        }
    });
    private string PresetDiscoveryJsonLd => JsonSerializer.Serialize(new
    {
        @context = "https://schema.org",
        @type = "ItemList",
        name = ClusterNavigationTitle,
        itemListElement = ClusterPages
            .Select((page, index) => new
            {
                @type = "ListItem",
                position = index + 1,
                name = page.Title,
                url = ToAbsolute(page.Path)
            })
            .ToArray()
    });

    private IReadOnlyList<string> AvailableSubcategories => PresetsCollection
        .Where(MatchesCategory)
        .Where(MatchesPlatform)
        .Select(x => x.GetSubcategory(ActiveContentLanguage))
        .Distinct(StringComparer.CurrentCultureIgnoreCase)
        .OrderBy(x => x, StringComparer.CurrentCultureIgnoreCase)
        .ToList();

    private IReadOnlyList<string> AvailablePlatforms
        => AiProviderCatalog.BuildPresetFilterOptions(
            PresetsCollection
                .Where(MatchesCategory)
                .Select(x => x.DefaultPlatform));

    private int TotalFilteredPresetCount => GetFilteredPresets().Count;
    private int TotalPresetLibraryCount => PresetsCollection.Count;
    private bool HasMorePresetsToLoad => VisiblePresetCount < TotalFilteredPresetCount;
    private string PresetLibraryCountLabel => IsGerman
        ? $"{TotalPresetLibraryCount.ToString("N0", CultureInfo.CurrentCulture)} Presets gesamt"
        : $"{TotalPresetLibraryCount.ToString("N0", CultureInfo.CurrentCulture)} total presets";

    private IReadOnlyList<PromptPreset> VisiblePresets
        => GetFilteredPresets()
            .Take(Math.Min(VisiblePresetCount, TotalFilteredPresetCount))
            .ToList();

    protected override async Task OnInitializedAsync()
    {
        PresetsCollection = await PresetService.GetAllAsync();
        ClusterPages = SeoLandingPageService.GetClusterPages(CurrentLanguage);
        ApplyCategoryQuery();
        NormalizeFilterValues();
        InvalidatePresetWindow();
    }

    protected override void OnParametersSet()
    {
        ApplyCategoryQuery();
        NormalizeFilterValues();
        InvalidatePresetWindow();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            DotNetReference = DotNetObjectReference.Create(this);
        }

        if (firstRender || ObserverRefreshPending)
        {
            ObserverRefreshPending = false;
            await RefreshPresetScrollObserverAsync();
        }
    }

    private void OnCategoryChanged()
    {
        SubcategoryFilter = "all";
        PlatformFilter = "all";
        NormalizeFilterValues();
        InvalidatePresetWindow();
    }

    private void OnFilterChanged()
    {
        NormalizeFilterValues();
        InvalidatePresetWindow();
    }

    private void ApplyCategoryQuery()
    {
        if (Category == LastAppliedCategoryQuery)
        {
            return;
        }

        LastAppliedCategoryQuery = Category;

        if (string.IsNullOrWhiteSpace(Category))
        {
            CategoryFilter = "all";
            return;
        }

        if (!Enum.TryParse<PresetCategory>(Category, true, out var parsed))
        {
            return;
        }

        CategoryFilter = parsed.ToString();
    }

    private void NormalizeFilterValues()
    {
        if (!AvailablePlatforms.Contains(PlatformFilter, StringComparer.OrdinalIgnoreCase))
        {
            PlatformFilter = "all";
        }

        if (!AvailableSubcategories.Contains(SubcategoryFilter, StringComparer.CurrentCultureIgnoreCase))
        {
            SubcategoryFilter = "all";
        }
    }

    [JSInvokable]
    public async Task OnPresetScrollThresholdReached()
    {
        if (IsLoadingMorePresets || !HasMorePresetsToLoad)
        {
            return;
        }

        IsLoadingMorePresets = true;
        await InvokeAsync(StateHasChanged);

        await Task.Delay(60);
        VisiblePresetCount = Math.Min(TotalFilteredPresetCount, VisiblePresetCount + PresetBatchSize);
        IsLoadingMorePresets = false;
        ObserverRefreshPending = true;
        await InvokeAsync(StateHasChanged);
    }

    private bool MatchesCategory(PromptPreset preset)
        => CategoryFilter.Equals("all", StringComparison.OrdinalIgnoreCase)
           || preset.Category.ToString().Equals(CategoryFilter, StringComparison.OrdinalIgnoreCase);

    private bool MatchesPlatform(PromptPreset preset)
        => PlatformFilter.Equals("all", StringComparison.OrdinalIgnoreCase)
           || preset.DefaultPlatform.Equals(PlatformFilter, StringComparison.OrdinalIgnoreCase);

    private bool MatchesSubcategory(PromptPreset preset)
    {
        if (SubcategoryFilter.Equals("all", StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }

        var localizedSubcategory = preset.GetSubcategory(ActiveContentLanguage);
        return localizedSubcategory.Equals(SubcategoryFilter, StringComparison.CurrentCultureIgnoreCase);
    }

    private int ComputeRelevanceScore(PromptPreset preset, string query)
    {
        if (string.IsNullOrWhiteSpace(query))
        {
            return 1;
        }

        return ScoreForLanguage(
            query,
            preset.GetTitle(ActiveContentLanguage),
            preset.GetDescription(ActiveContentLanguage),
            preset.GetSubcategory(ActiveContentLanguage),
            preset.GetTags(ActiveContentLanguage));
    }

    private static int ScoreForLanguage(string query, string title, string description, string subcategory, IReadOnlyList<string> tags)
    {
        var score = 0;

        if (title.Contains(query, StringComparison.CurrentCultureIgnoreCase))
        {
            score += 12;
        }

        if (subcategory.Contains(query, StringComparison.CurrentCultureIgnoreCase))
        {
            score += 7;
        }

        if (description.Contains(query, StringComparison.CurrentCultureIgnoreCase))
        {
            score += 5;
        }

        var tagHits = tags.Count(x => x.Contains(query, StringComparison.CurrentCultureIgnoreCase));
        score += tagHits * 4;

        return score;
    }

    private string? GetCategoryLandingPath(PresetCategory category)
        => SeoLandingPageService.GetCategoryLandingPath(CurrentLanguage, category);

    private string GetCategoryLabel(PresetCategory category)
        => CategoryLabelResolver.Resolve(category.ToString(), L);

    private string GetTitle(PromptPreset preset) => preset.GetTitle(ActiveContentLanguage);
    private string GetDescription(PromptPreset preset) => preset.GetDescription(ActiveContentLanguage);
    private string GetSubcategory(PromptPreset preset) => preset.GetSubcategory(ActiveContentLanguage);
    private IReadOnlyList<string> GetTags(PromptPreset preset) => preset.GetTags(ActiveContentLanguage);
    private string GetExampleInput(PromptPreset preset) => preset.GetExampleInput(ActiveContentLanguage);
    private string GetExamplePrompt(PromptPreset preset) => preset.GetExamplePrompt(ActiveContentLanguage);

    private string ToAbsolute(string relativePath)
    {
        var normalized = string.IsNullOrWhiteSpace(relativePath) ? "/" : relativePath;
        return new Uri(new Uri(Navigation.BaseUri), normalized).ToString();
    }

    private IReadOnlyList<PromptPreset> GetFilteredPresets()
    {
        var signature = BuildFilterSignature();
        if (signature.Equals(LastFilterSignature, StringComparison.Ordinal))
        {
            return CachedFilteredPresets;
        }

        LastFilterSignature = signature;
        CachedFilteredPresets = BuildFilteredPresets();
        return CachedFilteredPresets;
    }

    private IReadOnlyList<PromptPreset> BuildFilteredPresets()
    {
        var query = SearchText.Trim();

        var scored = PresetsCollection
            .Where(MatchesCategory)
            .Where(MatchesSubcategory)
            .Where(MatchesPlatform)
            .Select(x => new ScoredPreset(x, ComputeRelevanceScore(x, query)))
            .Where(x => string.IsNullOrWhiteSpace(query) || x.Score > 0)
            .ToList();

        return SortFilter switch
        {
            "popularity" => scored
                .OrderByDescending(x => x.Preset.PopularityScore)
                .ThenByDescending(x => x.Score)
                .ThenBy(x => x.Preset.GetTitle(ActiveContentLanguage), StringComparer.CurrentCultureIgnoreCase)
                .Select(x => x.Preset)
                .ToList(),
            "title" => scored
                .OrderBy(x => x.Preset.GetTitle(ActiveContentLanguage), StringComparer.CurrentCultureIgnoreCase)
                .Select(x => x.Preset)
                .ToList(),
            _ => scored
                .OrderByDescending(x => x.Score)
                .ThenByDescending(x => x.Preset.PopularityScore)
                .ThenBy(x => x.Preset.GetTitle(ActiveContentLanguage), StringComparer.CurrentCultureIgnoreCase)
                .Select(x => x.Preset)
                .ToList()
        };
    }

    private string BuildFilterSignature()
        => string.Join('|',
            CurrentLanguage,
            SearchText.Trim(),
            CategoryFilter,
            SubcategoryFilter,
            PlatformFilter,
            SortFilter);

    private void InvalidatePresetWindow()
    {
        LastFilterSignature = string.Empty;
        CachedFilteredPresets = [];
        VisiblePresetCount = InitialPresetBatchSize;
        ObserverRefreshPending = true;
    }

    private async Task RefreshPresetScrollObserverAsync()
    {
        if (DotNetReference is null)
        {
            return;
        }

        if (HasMorePresetsToLoad)
        {
            await JsRuntime.InvokeVoidAsync("promptUiInfiniteScroll.observe", PresetScrollObserverKey, PresetLoadSentinel, DotNetReference);
            IsObserverAttached = true;
            return;
        }

        if (IsObserverAttached)
        {
            await JsRuntime.InvokeVoidAsync("promptUiInfiniteScroll.unobserve", PresetScrollObserverKey);
            IsObserverAttached = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (IsObserverAttached)
        {
            try
            {
                await JsRuntime.InvokeVoidAsync("promptUiInfiniteScroll.unobserve", PresetScrollObserverKey);
            }
            catch
            {
                // Ignore dispose-time JS failures.
            }
        }

        DotNetReference?.Dispose();
    }

    private sealed record ScoredPreset(PromptPreset Preset, int Score);
}
