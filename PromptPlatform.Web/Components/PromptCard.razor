@using PromptPlatform.Web.Models
@inject IJSRuntime JsRuntime

<div class="card border-0 shadow-sm h-100 prompt-card">
    <div class="card-body d-flex flex-column">
        <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
            <div>
                <h3 class="h5 mb-1">@Prompt.GetTitle(Language)</h3>
                @if (!string.IsNullOrWhiteSpace(CategoryLabel))
                {
                    <span class="badge text-bg-light border">@CategoryLabel</span>
                }
            </div>
            @if (!string.IsNullOrWhiteSpace(PopularityLabel))
            {
                <span class="small text-secondary">@PopularityLabel</span>
            }
        </div>

        <p class="text-secondary small mb-3">@PreviewText</p>

        <div class="mt-auto d-flex flex-wrap gap-2">
            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="CopyAsync">@CopyLabel</button>
            <a class="btn btn-sm btn-primary" href="@OpenUrl">@OpenLabel</a>
            @if (!string.IsNullOrWhiteSpace(ShareUrl))
            {
                <a class="btn btn-sm btn-outline-primary" href="@ShareUrl">@ShareLabel</a>
            }
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public PromptPreset Prompt { get; set; } = default!;

    [Parameter]
    public string Language { get; set; } = "en";

    [Parameter]
    public string PreviewText { get; set; } = string.Empty;

    [Parameter]
    public string OpenUrl { get; set; } = string.Empty;

    [Parameter]
    public string? ShareUrl { get; set; }

    [Parameter]
    public string CopyLabel { get; set; } = "Copy";

    [Parameter]
    public string OpenLabel { get; set; } = "Open";

    [Parameter]
    public string ShareLabel { get; set; } = "Share";

    [Parameter]
    public string? CategoryLabel { get; set; }

    [Parameter]
    public string? PopularityLabel { get; set; }

    [Parameter]
    public string? CopyText { get; set; }

    private async Task CopyAsync()
    {
        if (string.IsNullOrWhiteSpace(CopyText))
        {
            return;
        }

        await JsRuntime.InvokeVoidAsync("promptUi.copyText", CopyText);
    }
}
